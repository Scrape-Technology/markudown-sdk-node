{
  "name": "markudown",
  "version": "0.1.0",
  "description": "Node.js / TypeScript SDK for MarkUDown — AI data extraction infrastructure",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "keywords": ["scraping", "web-scraping", "data-extraction", "ai", "markudown"],
  "homepage": "https://scrapetechnology.com/markudown",
  "repository": {
    "type": "git",
    "url": "https://github.com/Scrape-Technology/MarkUDown-Engine"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  }
}
